# Server
PORT=3100
HOST=0.0.0.0

# Browser
MAX_TEXT_LENGTH=30000
DEFAULT_TIMEOUT=15000

# Rate limiting
RATE_LIMIT_RPM=60

# API Keys (comma-separated for multiple)
API_KEYS=

# Reddit OAuth (free — create at https://www.reddit.com/prefs/apps, app type: "script")
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# Set this to your Reddit username (used in the User-Agent string)
# REDDIT_USERNAME=

# x402 Payment (Celo USDC)
# CELO_RPC_URL=https://forno.celo.org
# PAYMENT_RECIPIENT_ADDRESS=
# PRICE_PER_REQUEST=0.02
